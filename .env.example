# Скопируй в .env и заполни своими ключами

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Твой личный chat id (узнать у @userinfobot) — сюда Muse шлёт идеи.
# Пусто = проактивные сообщения выключены
TELEGRAM_CHAT_ID=

# Раз в сколько дней Muse приносит идеи (1-3, по умолчанию 2)
MUSE_INTERVAL_DAYS=2

# Ключ Gemini API (aistudio.google.com, free tier)
GEMINI_API_KEY=

# Ключ Groq (console.groq.com, free tier) — резервный LLM-провайдер
GROQ_API_KEY=

# Таймзона пользователя (по умолчанию Europe/Moscow)
TIMEZONE=Europe/Moscow

# Опционально: ключ Semantic Scholar (api.semanticscholar.org) —
# без него работает, но с меньшими лимитами (429 = норма, источник пропустится)
S2_API_KEY=

# Опционально: YouTube Data API v3 — включить в той же консоли Google Cloud,
# что и Gemini (console.cloud.google.com → APIs → YouTube Data API v3).
# Нужен для длительности видео-задач; без него видео добавляются без времени
YOUTUBE_API_KEY=
